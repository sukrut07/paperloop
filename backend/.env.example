PORT=5001
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/paperloop
CORS_ORIGIN=http://localhost:3000

PINATA_API_KEY=replace_with_pinata_api_key
PINATA_SECRET_API_KEY=replace_with_pinata_secret

POLYGON_NETWORK=amoy
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
PAPERLOOP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

REQUIRE_FIREBASE_AUTH=false
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
